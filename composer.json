{
    "name": "braseidon/vaal-api",
    "description": "PHP client for the Path of Exile API with OAuth 2.0, rate limiting, and full endpoint coverage",
    "type": "library",
    "keywords": ["path-of-exile", "poe", "ggg", "api", "oauth", "rate-limiting"],
    "license": "MIT",
    "authors": [
        {
            "name": "Brandon Johnson",
            "email": "bluejd910@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "league/oauth2-client": "^2.7",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Braseidon\\VaalApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Braseidon\\VaalApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Braseidon\\VaalApi\\Laravel\\VaalApiServiceProvider"
            ],
            "aliases": {
                "VaalApi": "Braseidon\\VaalApi\\Laravel\\Facades\\VaalApi"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
